# このファイルをコピーして .env を作成してください
# cp .env.example .env
# .env は .gitignore に追加されており、リポジトリにコミットされません

# PostgreSQL
POSTGRES_PASSWORD=your-strong-password-here

# バックエンド
DATABASE_URL=postgres://app:your-strong-password-here@db:5432/bus_logistics
JWT_SECRET=your-random-secret-at-least-32-chars-here

# 管理者API認証キー（招待コード発行・一覧取得に使用）
# 推測困難なランダム文字列を設定してください
# 例: openssl rand -hex 32
ADMIN_KEY=your-admin-key-here
